# --- Python / runtime ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# --- OS ---
.DS_Store

# district.sql and "state 1.sql" (the one-time boundary dumps loaded by
# scripts/setup_database.sh) are committed via Git LFS — see .gitattributes —
# instead of being excluded, since they're needed for a from-scratch clone.

# --- Orphaned local cache from the old, unused grid_generator.py path ---
# The live app fetches grid cells from PostGIS via db.py instead; these files
# belong to an earlier local-file-cache implementation that nothing calls.
/data/grids/
/data/districts.geojson
/data/state.geojson

# --- Superseded pre-v2 precompute output ---
# app.py only ever reads the *_v2.json files; these v1 files predate the
# adjustable-threshold rework and are never read.
/data/accident_hospital_safety.json
/data/accident_ambulance_safety.json
/data/accident_bloodbank_safety.json
/data/district_scorecard.json

# --- Runtime state written while the app runs ---
# Recreated automatically (dataset_manager.py / grid_reach.py fall back safely
# when these are missing) — don't want a live deployment's uploaded dataset
# or per-district OSRM cache showing up as local git changes.
/data/grid_reach/
/data/accidents_active.csv
/data/dataset_state.json
/dashboard/cache/

# --- Superseded 3D-readiness feature ---
# That view was removed from the app; this is its leftover output/docs.
/dashboard/static/scored/
/dashboard/templates/_nav.html
/dashboard/grid_generator.py
/scripts/score_engine.py
/scripts/export_geojson.py
/READINESS_README.md
/SCORING_SPEC.md
/view_3d.command
/data/coverage_demo_backups/
